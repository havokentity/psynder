# Psynder clang-tidy config. The DOTS check set (§3.6 of DESIGN.md) is
# enforced here: no virtual in hot subsystems, no shared_ptr in engine
# runtime, no per-frame new/delete. Checks marked WarningsAsErrors fail CI.
---
Checks: >
  -*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  cert-*,
  -cert-err58-cpp,
  cppcoreguidelines-*,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-non-private-member-variables-in-classes,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-type-reinterpret-cast,
  -cppcoreguidelines-pro-type-static-cast-downcast,
  google-*,
  -google-readability-todo,
  -google-runtime-references,
  hicpp-*,
  -hicpp-no-array-decay,
  -hicpp-signed-bitwise,
  misc-*,
  -misc-non-private-member-variables-in-classes,
  modernize-*,
  -modernize-use-trailing-return-type,
  -modernize-pass-by-value,
  performance-*,
  portability-*,
  readability-*,
  -readability-identifier-length,
  -readability-magic-numbers,

WarningsAsErrors: >
  bugprone-use-after-move,
  bugprone-dangling-handle,
  bugprone-string-constructor,
  bugprone-suspicious-memset-usage,
  cert-flp30-c,
  cppcoreguidelines-avoid-goto,
  cppcoreguidelines-slicing,
  hicpp-exception-baseclass,
  misc-misplaced-const,
  modernize-use-nullptr,
  modernize-use-override,
  performance-move-const-arg,
  performance-noexcept-move-constructor,
  performance-unnecessary-value-param,
  readability-misleading-indentation,

HeaderFilterRegex: '(engine|tools|samples|tests)/.*\.h$'

# CheckOptions enforcement of project style; bare snake_case for funcs,
# PascalCase for types, kCamelCase for constants.
CheckOptions:
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.StructCase
    value: CamelCase
  - key: readability-identifier-naming.EnumCase
    value: CamelCase
  - key: readability-identifier-naming.FunctionCase
    value: lower_case
  - key: readability-identifier-naming.MethodCase
    value: CamelCase
  - key: readability-identifier-naming.VariableCase
    value: lower_case
  - key: readability-identifier-naming.ParameterCase
    value: lower_case
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case
  - key: readability-identifier-naming.ConstexprVariableCase
    value: CamelCase
  - key: readability-identifier-naming.ConstexprVariablePrefix
    value: k
  - key: readability-identifier-naming.MemberSuffix
    value: _
  - key: readability-identifier-naming.PrivateMemberSuffix
    value: _
  - key: cppcoreguidelines-avoid-do-while.IgnoreMacros
    value: 'true'
