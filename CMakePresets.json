{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 28, "patch": 0 },
  "configurePresets": [
    {
      "name": "mac-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES":     "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "14.0",
        "CMAKE_C_COMPILER":            "clang",
        "CMAKE_CXX_COMPILER":          "clang++"
      }
    },
    {
      "name": "mac-debug",
      "displayName": "Mac · Debug",
      "inherits": "mac-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":            "Debug",
        "PSYNDER_ENABLE_TRACY":        "ON",
        "PSYNDER_ENABLE_SANITIZERS":   "ON"
      }
    },
    {
      "name": "mac-release",
      "displayName": "Mac · Release",
      "inherits": "mac-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":            "Release",
        "PSYNDER_ENABLE_TRACY":        "OFF",
        "PSYNDER_ENABLE_SANITIZERS":   "OFF"
      }
    },
    {
      "name": "mac-relwithdebinfo",
      "displayName": "Mac · RelWithDebInfo",
      "inherits": "mac-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":            "RelWithDebInfo",
        "PSYNDER_ENABLE_TRACY":        "ON"
      }
    },

    {
      "name": "win-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER":   "cl",
        "CMAKE_CXX_COMPILER": "cl"
      },
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "hostOS": [ "Windows" ]
        }
      }
    },
    {
      "name": "win-debug",
      "displayName": "Windows · Debug (MSVC)",
      "inherits": "win-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":     "Debug",
        "PSYNDER_ENABLE_TRACY": "ON"
      }
    },
    {
      "name": "win-release",
      "displayName": "Windows · Release (MSVC)",
      "inherits": "win-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":     "Release",
        "PSYNDER_ENABLE_TRACY": "OFF"
      }
    },
    {
      "name": "win-clang-debug",
      "displayName": "Windows · Debug (clang-cl)",
      "inherits": "win-base",
      "cacheVariables": {
        "CMAKE_C_COMPILER":   "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "CMAKE_BUILD_TYPE":   "Debug",
        "PSYNDER_ENABLE_TRACY": "ON"
      }
    },
    {
      "name": "win-clang-release",
      "displayName": "Windows · Release (clang-cl)",
      "inherits": "win-base",
      "cacheVariables": {
        "CMAKE_C_COMPILER":   "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "CMAKE_BUILD_TYPE":   "Release",
        "PSYNDER_ENABLE_TRACY": "OFF"
      }
    },

    {
      "name": "linux-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER":   "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux · Debug",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":     "Debug",
        "PSYNDER_ENABLE_TRACY": "ON"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux · Release",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":     "Release",
        "PSYNDER_ENABLE_TRACY": "OFF"
      }
    },
    {
      "name": "linux-asan-debug",
      "displayName": "Linux · Debug + ASan/UBSan",
      "inherits": "linux-debug",
      "cacheVariables": {
        "PSYNDER_ENABLE_SANITIZERS": "ON",
        "PSYNDER_ENABLE_TRACY":      "OFF"
      }
    }
  ],
  "buildPresets": [
    { "name": "mac-debug",          "configurePreset": "mac-debug",          "jobs": 0 },
    { "name": "mac-release",        "configurePreset": "mac-release",        "jobs": 0 },
    { "name": "mac-relwithdebinfo", "configurePreset": "mac-relwithdebinfo", "jobs": 0 },
    { "name": "win-debug",          "configurePreset": "win-debug",          "jobs": 0 },
    { "name": "win-release",        "configurePreset": "win-release",        "jobs": 0 },
    { "name": "win-clang-debug",    "configurePreset": "win-clang-debug",    "jobs": 0 },
    { "name": "win-clang-release",  "configurePreset": "win-clang-release",  "jobs": 0 },
    { "name": "linux-debug",        "configurePreset": "linux-debug",        "jobs": 0 },
    { "name": "linux-release",      "configurePreset": "linux-release",      "jobs": 0 },
    { "name": "linux-asan-debug",   "configurePreset": "linux-asan-debug",   "jobs": 0 }
  ],
  "testPresets": [
    { "name": "mac-debug",       "configurePreset": "mac-debug",      "output": { "outputOnFailure": true }, "execution": { "repeat": { "mode": "until-pass", "count": 2 } } },
    { "name": "mac-release",     "configurePreset": "mac-release",    "output": { "outputOnFailure": true }, "execution": { "repeat": { "mode": "until-pass", "count": 2 } } },
    { "name": "linux-debug",     "configurePreset": "linux-debug",    "output": { "outputOnFailure": true }, "execution": { "repeat": { "mode": "until-pass", "count": 2 } } },
    { "name": "linux-release",   "configurePreset": "linux-release",  "output": { "outputOnFailure": true }, "execution": { "repeat": { "mode": "until-pass", "count": 2 } } },
    { "name": "win-debug",       "configurePreset": "win-debug",      "output": { "outputOnFailure": true }, "execution": { "repeat": { "mode": "until-pass", "count": 2 } } },
    { "name": "win-release",     "configurePreset": "win-release",    "output": { "outputOnFailure": true }, "execution": { "repeat": { "mode": "until-pass", "count": 2 } } }
  ]
}
