{
  "name": "psynder-editor-web",
  "version": "0.1.0",
  "private": true,
  "description": "Psynder editor panels — React + TypeScript, Chrome app windows. Lane 20.",
  "type": "module",
  "scripts": {
    "gen:ipc": "python3 ../ipc/idl/psyidl.py --input ../ipc/protocol.psy --ts-out src/ipc/protocol.gen.ts",
    "pretypecheck": "npm run gen:ipc",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "prebuild": "npm run gen:ipc",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@msgpack/msgpack": "^3.0.0-beta2"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
